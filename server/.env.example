NODE_ENV=development
PORT=5000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Statify_POS
DB_USER=postgres
DB_PASSWORD=ef083726860341a0aa9a68cfafc1f5c8
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=10000
DB_POOL_CONNECT_TIMEOUT=2000

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separate multiple origins for production)
CORS_ORIGIN=http://localhost:5173

# Bcrypt rounds (10-12 for production)
BCRYPT_ROUNDS=10

# App URL (used in password reset links, email footers)
APP_URL=https://demo.statify.co.ke

# SMTP — Statify mail server
# Port 465 = SSL (SMTP_SECURE=true) | Port 587 = STARTTLS (SMTP_SECURE=false)
SMTP_HOST=mail.statify.co.ke
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@statify.co.ke
SMTP_PASS=your_email_password_here
EMAIL_FROM=Statify POS <support@statify.co.ke>
